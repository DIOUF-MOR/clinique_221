{% extends 'base.html.twig' %}

{% block title %}Éditer l'utilisateur{% endblock %}

{% block body %}
<div class="container mt-5">
    <h1>Éditer l'utilisateur</h1>
    
    <div class="card mt-4">
        <div class="card-header">
            <h3>{{ user.firstname }} {{ user.lastname }}</h3>
        </div>
        <div class="card-body">
            {{ form_start(form) }}
                <div class="mb-3">
                    {{ form_row(form.roles) }}
                </div>
                
                <div class="mb-3">
                    {{ form_row(form.isActive) }}
                </div>
                
                <div>
                    <button type="submit" class="btn btn-primary">Enregistrer</button>
                    <a href="{{ path('app_admin') }}" class="btn btn-secondary">Annuler</a>
                </div>
            {{ form_end(form) }}
        </div>
    </div>
</div>
{% endblock %}